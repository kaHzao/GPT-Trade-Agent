# ─── GPT Trade Agent — Environment Variables ──────────────────────────────────
# Salin file ini menjadi .env dan isi nilai yang sesuai:
#   cp .env.example .env
#   nano .env

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Buat bot baru via @BotFather di Telegram → dapatkan token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Chat ID tempat bot mengirim alert
# Kirim pesan ke bot kamu, lalu cek via: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Trading Parameters ─────────────────────────────────────────────────────────
# Collateral (USDC) per trade
COLLATERAL_USDC=10

# Leverage (1-10x, disarankan 2-5x)
LEVERAGE=2

# DRY_RUN=true  → simulasi saja, tidak ada trade nyata (default: true)
# DRY_RUN=false → trade sungguhan di Jupiter Perps
DRY_RUN=true

# ── Jupiter / Solana ──────────────────────────────────────────────────────────
# Private key wallet Solana (base58 atau array JSON)
# PENTING: Jangan pernah share atau commit file .env ke GitHub!
SOLANA_PRIVATE_KEY=your_solana_private_key_here

# RPC endpoint Solana (gunakan yang cepat: Helius, QuickNode, dll)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
